import time

# Main System Controller
class LibraryBorrowingSystem:
    def __init__(self):
        print("Initializing Library Borrowing System...")
        self.setup_database()  # You will define this (list/dict/CSV)
        self.setup_hardware()  # Initialize RFID & Barcode scanner
        self.setup_wifi()      # Connect to network for notifications

    # ------------------------------------------------------------------------
    # MAIN PROCESS: BORROW A BOOK
    # This is your core workflow from the student's perspective
    # ------------------------------------------------------------------------
    def borrow_book_workflow(self):
        """Guides the student through the entire borrowing process."""
        
        print("\n" + "="*50)
        print("START BOOK BORROWING")
        print("="*50)
        
        # 1. SCAN STUDENT ID
        student_data = self.scan_student_id()
        if not student_data:
            print("Error: Could not read student ID.")
            return False
        
        print(f"Student Identified: {student_data['name']}")
        
        # 2. CHECK FOR OVERDUE BOOKS
        if self.has_overdue_books(student_data['id']):
            print("❌ ACTION BLOCKED: Student has overdue books.")
            self.send_alert_to_supervisor(student_data, "OVERDUE_BLOCK")
            return False
        
        # 3. SCAN BOOK BARCODE
        book_data = self.scan_book_barcode()
        if not book_data:
            print("Error: Could not read book barcode.")
            return False
        
        print(f"Book Identified: {book_data['title']}")
        
        # 4. CHECK BOOK AVAILABILITY
        if not self.is_book_available(book_data['barcode']):
            print("❌ Book is already borrowed.")
            return False
        
        # 5. PROCESS THE TRANSACTION
        if self.process_borrowing(student_data, book_data):
            print("✅ BOOK SUCCESSFULLY BORROWED!")
            # 6. SEND NOTIFICATION TO SUPERVISOR
            self.send_alert_to_supervisor(student_data, book_data, "BORROW")
            return True
        else:
            print("❌ Transaction failed.")
            return False

    # ------------------------------------------------------------------------
    # SECONDARY PROCESS: RETURN A BOOK
    # ------------------------------------------------------------------------
    def return_book_workflow(self):
        """Handles the book return process."""
        print("\n" + "="*50)
        print("START BOOK RETURN")
        print("="*50)
        
        # 1. SCAN BOOK BARCODE
        book_data = self.scan_book_barcode()
        if not book_data:
            return False
        
        # 2. UPDATE RECORDS
        if self.process_return(book_data):
            print("✅ Book return recorded.")
            # Optional: Send return confirmation alert
            self.send_alert_to_supervisor(None, book_data, "RETURN")
            return True
        else:
            print("❌ Return processing error.")
            return False

