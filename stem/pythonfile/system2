    def is_book_available(self, book_barcode):
        """Checks if the book is currently in the library."""
        return self.books.get(book_barcode, {}).get('available', False)
    
    def process_borrowing(self, student_data, book_data):
        """Saves the borrow transaction to the database."""
        # 1. Record transaction with timestamp and due date (e.g., +14 days)
        # 2. Update book status to 'not available'
        new_transaction = {
            'student_id': student_data['id'],
            'book_barcode': book_data['barcode'],
            'timestamp': time.time(),
            'action': 'BORROW'
        }
        self.transactions.append(new_transaction)
        self.books[book_data['barcode']]['available'] = False
        return True
    
    def process_return(self, book_data):
        """Saves the return transaction to the database."""
        # 1. Record return transaction
        # 2. Update book status to 'available'
        self.books[book_data['barcode']]['available'] = True
        return True
    
